NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Database
MONGO_URI=mongodb://localhost:27017/b2c

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# OAuth (Google) — required only to enable POST /auth/oauth/google
GOOGLE_CLIENT_ID=

# CORS
CORS_ORIGIN=http://localhost:3000

# Job queue (BullMQ)
REDIS_URL=redis://localhost:6379
# Set to false on Render until a live Redis instance is configured
REDIS_ENABLED=true

# AI provider (shared across course/exercise/quiz/exam generation)
AI_PROVIDER_API_KEY=

# Sandbox execution (labs)
SANDBOX_EXECUTION_PROVIDER=docker-local
SANDBOX_EXECUTION_TIMEOUT_MS=5000
SANDBOX_MAX_MEMORY_MB=256

# Email (daily notifications)
EMAIL_PROVIDER_API_KEY=

# Stripe (subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
